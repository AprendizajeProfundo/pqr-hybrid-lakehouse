# Supabase overlay
SUPABASE_URL=http://localhost:8000
SUPABASE_API_URL=http://localhost:8000
SUPABASE_SITE_URL=http://localhost:3002
SUPABASE_JWT_SECRET=replace-with-32chars-min
SUPABASE_ANON_KEY=replace-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-service-role-key
SUPABASE_DB_AUTHENTICATOR_PASSWORD=replace-authenticator-password

# Data Plane
RUSTFS_ACCESS_KEY=replace-rustfs-access
RUSTFS_SECRET_KEY=replace-rustfs-secret
